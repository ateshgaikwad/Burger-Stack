pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('compose'){
            steps {
              sh "docker-compose -f devops-microservices/docker-compose.yml build " 
            }
        }
        stage('Run') {
            steps {
                sh 'docker-compose -f devops-microservices/docker-compose.yml up'
            }
        }
        stage('down') {
            steps {
                sh 'docker-compose -f devops-microservices/docker-compose.yml down'
            }
        }
}
}
